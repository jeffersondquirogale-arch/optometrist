# Configuración de la base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/optometrist_db"

# Puerto del servidor
PORT=3000

# Entorno de ejecución
NODE_ENV=development

# CORS - origen permitido del frontend
CORS_ORIGIN=http://localhost:5173

# JWT — secreto para firmar tokens (mínimo 32 caracteres)
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio_32chars"
JWT_EXPIRES_IN=8h

# ──────────────────────────────────────────────────────────────────────────────
# Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores antes de iniciar.
# ⚠️  NUNCA subas el archivo .env real al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Base de datos ────────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/optometrist_db"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# Entorno de ejecución: development | production | test
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origen(es) permitidos para el frontend.
# En producción, usa la URL exacta del frontend desplegado.
CORS_ORIGIN=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secreto para firmar tokens JWT.
# ⚠️  DEBE tener al menos 32 caracteres y ser un valor aleatorio y único.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio_32chars_minimo"

# Duración del token JWT (ej: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h

# ─── Seed de usuario administrador inicial ────────────────────────────────────
# Estas variables son opcionales y solo se usan al ejecutar `npm run prisma:seed`.
# Si no se definen, el seed usa los valores predeterminados (ver README).
# ⚠️  En producción, define estas variables antes de ejecutar el seed y
#     cambia la contraseña después del primer inicio de sesión.
SEED_ADMIN_EMAIL=admin@clinica.com
SEED_ADMIN_PASSWORD=CambiaMeAhora123!
SEED_ADMIN_NAME="Administrador"

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Gender {
  MASCULINO
  FEMENINO
  OTRO
}

enum AppointmentStatus {
  PROGRAMADA
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_ASISTIO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  PARCIAL
  ANULADO
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        @default("STAFF")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  doctorProfile DoctorProfile?
  auditLogs     AuditLog[]

  @@map("users")
}

model DoctorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  licenseNumber  String
  specialty      String?
  clinicName     String?
  clinicAddress  String?
  clinicPhone    String?
  signature      String?  // URL o base64 de la firma
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  consultations Consultation[]

  @@map("doctor_profiles")
}

model Patient {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  documentId   String?   @unique
  birthDate    DateTime?
  gender       Gender?
  phone        String?
  email        String?
  address      String?
  occupation   String?
  notes        String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  appointments  Appointment[]
  consultations Consultation[]
  pathologies   PatientPathology[]

  @@map("patients")
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  scheduledAt DateTime
  reason      String?
  status      AppointmentStatus @default(PROGRAMADA)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation?

  @@map("appointments")
}

model Consultation {
  id              String        @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentId   String?       @unique
  consultationDate DateTime     @default(now())
  reason          String?
  diagnosis       String?
  treatment       String?
  control         String?
  observations    String?
  paymentStatus   PaymentStatus @default(PENDIENTE)
  paymentAmount   Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  patient               Patient                @relation(fields: [patientId], references: [id])
  doctor                DoctorProfile          @relation(fields: [doctorId], references: [id])
  appointment           Appointment?           @relation(fields: [appointmentId], references: [id])
  lensometry            Lensometry?
  visualAcuity          VisualAcuity?
  finalFormula          FinalFormula?
  ocularMotility        OcularMotility?
  externalExam          ExternalExam?
  cftaMoscopia          CftaMoscopia?
  keratometry           Keratometry?
  colorTest             ColorTest?
  stereopsisTest        StereopsisTest?
  refraction            Refraction?
  subjectiveRefraction  SubjectiveRefraction?
  eyeDiagram            EyeDiagram?
  pathologies           ConsultationPathology[]
  medicalNotes          MedicalNote[]

  @@map("consultations")
}

model Lensometry {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Ojo derecho (OD)
  odSphere       Float?
  odCylinder     Float?
  odAxis         Int?
  odAdd          Float?

  // Ojo izquierdo (OI)
  oiSphere       Float?
  oiCylinder     Float?
  oiAxis         Int?
  oiAdd          Float?

  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("lensometries")
}

model VisualAcuity {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Sin corrección
  odScVision     String?
  oiScVision     String?

  // Con corrección
  odCcVision     String?
  oiCcVision     String?

  // Otros
  nearVision     String?
  colorVision    String?
  iop            String?  // Presión intraocular
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("visual_acuities")
}

model FinalFormula {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Ojo derecho (OD)
  odSphere       Float?
  odCylinder     Float?
  odAxis         Int?
  odAdd          Float?
  odPrism        String?

  // Ojo izquierdo (OI)
  oiSphere       Float?
  oiCylinder     Float?
  oiAxis         Int?
  oiAdd          Float?
  oiPrism        String?

  // Datos del lente
  lensType       String?
  lensMaterial   String?
  lensCoating    String?
  dpOd           Float?  // Distancia pupilar OD
  dpOi           Float?  // Distancia pupilar OI
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("final_formulas")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── Phase 2 Models ───────────────────────────────────────────────────────────

model PatientPathology {
  id          String   @id @default(cuid())
  patientId   String
  name        String
  description String?
  diagnosedAt DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_pathologies")
}

model OcularMotility {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Versiones/Ducciones (texto libre o codificado)
  versions       String?
  ductions       String?
  coverTest      String?
  hirschberg     String?
  npc            String?  // Punto próximo de convergencia
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("ocular_motilities")
}

model ExternalExam {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Párpados, conjuntivas, córnea, etc.
  eyelids        String?
  conjunctiva    String?
  cornea         String?
  iris           String?
  pupil          String?
  lens           String?
  fundus         String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("external_exams")
}

model CftaMoscopia {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Campo visual / Tonometría / A-scan / Moscas volantes
  campimetry     String?
  tonometry      String?
  ascan          String?
  floaters       String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("cfta_moscopias")
}

model Keratometry {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Ojo derecho
  odK1           Float?
  odK1Axis       Int?
  odK2           Float?
  odK2Axis       Int?

  // Ojo izquierdo
  oiK1           Float?
  oiK1Axis       Int?
  oiK2           Float?
  oiK2Axis       Int?

  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("keratometries")
}

model ColorTest {
  id             String  @id @default(cuid())
  consultationId String  @unique

  odResult       String?
  oiResult       String?
  testType       String?  // Ishihara, Farnsworth, etc.
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("color_tests")
}

model StereopsisTest {
  id             String  @id @default(cuid())
  consultationId String  @unique

  result         String?
  testType       String?  // TNO, Randot, etc.
  seconds        Int?     // Arc seconds
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("stereopsis_tests")
}

model Refraction {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Refracción objetiva (esquiascopía/autorrefractómetro)
  // Ojo derecho
  odSphere       Float?
  odCylinder     Float?
  odAxis         Int?

  // Ojo izquierdo
  oiSphere       Float?
  oiCylinder     Float?
  oiAxis         Int?

  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("refractions")
}

model SubjectiveRefraction {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Refracción subjetiva
  // Ojo derecho
  odSphere       Float?
  odCylinder     Float?
  odAxis         Int?
  odAdd          Float?
  odVision       String?

  // Ojo izquierdo
  oiSphere       Float?
  oiCylinder     Float?
  oiAxis         Int?
  oiAdd          Float?
  oiVision       String?

  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("subjective_refractions")
}

model EyeDiagram {
  id             String  @id @default(cuid())
  consultationId String  @unique

  // Base64 images or text annotations
  odDiagram      String?
  oiDiagram      String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("eye_diagrams")
}

model ConsultationPathology {
  id             String   @id @default(cuid())
  consultationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("consultation_pathologies")
}

model MedicalNote {
  id             String   @id @default(cuid())
  consultationId String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("medical_notes")
}
